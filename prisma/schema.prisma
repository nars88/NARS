generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
 
}
// تعريف حالات الطلب كما هي في قاعدة البيانات
enum OrderStatus {
  Pending
  Confirmed
  Shipped
  Delivered
  Canceled

  @@map("order_status")
}

// تعريف المحافظات العراقية كما هي في قاعدة البيانات
enum IraqProvince {
  Baghdad
  Basra
  Nineveh
  Erbil
  Sulaymaniyah
  Duhok
  Kirkuk
  Anbar
  Diyala
  Babil
  Karbala
  Najaf
  Wasit
  Maysan
  Dhi_Qar
  Muthanna
  Qadisiyyah
  Saladin
  Halabja
  Unknown

  @@map("iraq_province")
}

// تمثيل جدول الطلبات (Orders)
model Order {
  id                String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customer_name     String
  phone_number      String
  item_code         String?
  province          IraqProvince @default(Unknown)
  full_address      String?
  product_details   Json         @default("[]")
  total_price       Decimal?     @db.Decimal(12, 0)
  delivery_fee      Decimal?     @default(0) @db.Decimal(12, 0)
  order_status      OrderStatus  @default(Pending)
  original_raw_text String
  ai_confidence     Int?         @db.SmallInt
  ai_model          String?
  employee_id       String?      @db.Uuid
  notes             String?
  created_at        DateTime     @default(now()) @db.Timestamptz
  updated_at        DateTime     @default(now()) @db.Timestamptz

  @@index([province], map: "orders_province_idx")
  @@index([order_status], map: "orders_status_idx")
  @@index([item_code], map: "orders_item_code_idx")
  @@index([created_at], map: "orders_created_at_idx")
  @@index([province, order_status, created_at], map: "orders_province_status_created_at_idx")
  @@map("orders")
}

// تمثيل جدول سجل التدقيق (اختياري)
model OrderAuditLog {
  id          String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  order_id    String       @db.Uuid
  changed_by  String?      @db.Uuid
  old_status  OrderStatus?
  new_status  OrderStatus?
  changed_at  DateTime     @default(now()) @db.Timestamptz
  note        String?

  @@map("order_audit_log")
}
